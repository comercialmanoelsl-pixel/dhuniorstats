<!DOCTYPE html><html lang="pt-br"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>DhuniorStats V18</title><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet"><style>
:root{--bg:#f3f6fb;--card:#fff;--line:#dbe3ee;--text:#07111f;--muted:#58677c;--green:#16a34a;--red:#dc2626;--yellow:#ca8a04;--shadow:0 16px 45px rgba(15,23,42,.10)}.dark{--bg:#06101b;--card:#0d1a2a;--line:rgba(148,163,184,.18);--text:#f8fafc;--muted:#93a4ba;--shadow:0 18px 60px rgba(0,0,0,.35)}*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:var(--bg);color:var(--text)}button,input,select{font-family:inherit}.app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}.sidebar{background:var(--card);border-right:1px solid var(--line);padding:28px 20px;position:sticky;top:0;height:100vh}.infinity:before{content:"∞";font-size:70px;line-height:38px;font-weight:900;color:#ef1f2d}.brand-title{font-size:25px;font-weight:900;margin-top:12px}.brand-title span{color:#ef1f2d}.slogan,.note{color:var(--muted);font-size:13px}.nav{display:grid;gap:10px;margin-top:28px}.nav button{border:0;background:transparent;text-align:left;padding:14px;border-radius:12px;color:var(--muted);font-weight:900;cursor:pointer}.nav button.active{color:var(--text);background:rgba(239,31,45,.12);box-shadow:inset 0 0 0 1px rgba(239,31,45,.22)}.theme{margin-top:20px;border:1px solid var(--line);border-radius:14px;padding:12px;width:100%;background:var(--card);color:var(--text);font-weight:800;cursor:pointer}.main{padding:26px}.topbar{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:18px}.controls{display:flex;gap:12px;flex-wrap:wrap}.pill,.field,.btn{background:var(--card);border:1px solid var(--line);padding:12px 15px;border-radius:12px;color:var(--text);font-weight:800;box-shadow:var(--shadow)}.btn{cursor:pointer}.content{display:grid;grid-template-columns:minmax(680px,1fr) 420px;gap:18px}.panel,.hero,.stat-card,.game-card,.summary-card{background:var(--card);border:1px solid var(--line);box-shadow:var(--shadow);border-radius:16px}.panel{padding:18px}.hero{min-height:235px;overflow:hidden}.hero-inner{height:100%;padding:24px;display:grid;grid-template-columns:1fr 170px 1fr;align-items:center}.team{text-align:center}.crest{width:86px;height:86px;margin:0 auto 12px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:32px;color:#fff;border:3px solid var(--line);overflow:hidden;background:#0f172a}.crest img{width:100%;height:100%;object-fit:contain;background:#fff;padding:8px}.team-name{font-size:18px;font-weight:900}.center{text-align:center}.badge{display:inline-block;background:#ef1f2d;color:#fff;font-weight:900;padding:7px 14px;border-radius:999px;font-size:12px;margin-bottom:10px}.period,.venue{color:var(--muted);font-size:13px}.minute{color:var(--green);font-size:24px;font-weight:900;margin:6px}.score{font-size:44px;font-weight:950}.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:14px 0}.summary-card{padding:18px}.summary-card small{display:block;color:var(--muted);font-weight:900;margin-bottom:8px}.summary-card h2{margin:0 0 10px;font-size:19px}.tag{display:inline-block;background:rgba(22,163,74,.13);color:var(--green);padding:7px 13px;border-radius:999px;font-weight:900;font-size:12px}.warn{background:rgba(250,204,21,.18);color:#a16207}.bad{background:rgba(239,68,68,.14);color:#ef4444}.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:14px}.stat-card{padding:16px}.stat-title{font-weight:900;font-size:12px;margin-bottom:12px;color:var(--muted)}.stat-values{display:flex;justify-content:space-between;font-size:26px;font-weight:900}.bar{margin-top:10px;height:8px;background:#dbe3ee;border-radius:999px;overflow:hidden;display:flex}.home{background:var(--green);height:100%}.away{background:#ef1f2d;height:100%}.mode-title{font-size:20px;font-weight:950;margin:0 0 10px}.pred-list{display:grid;gap:10px;margin-top:14px}.pred{font-weight:850;color:var(--muted);padding:10px 0;border-bottom:1px solid var(--line)}.pred.good{color:var(--green)}.pred.bad{color:var(--red)}.pred.pending{color:var(--muted)}.pred.neutral{color:var(--text)}.winner-box{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px}.winner-card{border:1px solid var(--line);border-radius:14px;padding:14px}.winner-card b{font-size:22px}.games-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(285px,1fr));gap:12px;margin-top:16px}.game-card{padding:14px;cursor:pointer}.game-card.active{border-color:#ef1f2d}.game-card small{color:var(--muted)}.game-row{display:flex;justify-content:space-between;gap:10px;margin-top:8px;font-weight:900}.game-score{color:#d97706;white-space:nowrap}.events{max-height:260px;overflow:auto;margin-top:12px}.event{display:grid;grid-template-columns:46px 1fr;gap:10px;padding:9px 0;border-bottom:1px solid var(--line);font-size:13px}.right{display:flex;flex-direction:column;gap:14px}.ai-box{margin-top:14px;padding:16px;border-radius:14px;background:rgba(148,163,184,.08);border:1px solid var(--line)}.base{color:var(--muted);line-height:1.55;display:grid;gap:8px;margin-top:12px}.mini-table{display:grid;gap:8px;margin-top:12px}.mini-row{display:grid;grid-template-columns:1fr 60px 60px 60px;gap:8px;padding:8px;border-bottom:1px solid var(--line);font-size:13px}.footer{color:var(--muted);font-size:13px;text-align:right;padding:16px 0}@media(max-width:1300px){.content{grid-template-columns:1fr}.right{display:grid;grid-template-columns:repeat(2,1fr)}}@media(max-width:900px){.app{grid-template-columns:1fr}.sidebar{position:relative;height:auto}.stats-grid,.summary-grid,.right{grid-template-columns:1fr 1fr}.hero-inner{grid-template-columns:1fr;gap:20px}}@media(max-width:640px){.main{padding:16px}.stats-grid,.summary-grid,.right,.winner-box{display:grid;grid-template-columns:1fr}.score{font-size:38px}}
</style></head><body><div class="app"><aside class="sidebar"><div class="infinity"></div><div class="brand-title">Dhunior<span>Stats</span></div><div class="slogan">Além das estatísticas</div><div class="nav"><button class="active" data-mode="winners">🧠 Prováveis vencedores</button><button data-mode="radar">📡 Radar</button><button data-mode="final">🎯 Finalizações</button><button data-mode="target">🥅 Chutes no gol</button><button data-mode="corners">🚩 Escanteios</button><button data-mode="post">📌 Pós-jogo</button><button data-mode="context">📊 Contexto</button><button data-mode="news">📰 Notícias</button></div><p class="note">V18: SportMonks principal, fallback histórico e pós-jogo.</p><button class="theme" id="themeBtn">Alternar tema</button></aside><main class="main"><div class="topbar"><div class="controls"><div class="pill">Radar DhuniorStats</div><input class="field" type="date" id="dateInput"><input class="field" type="text" id="searchInput" placeholder="Buscar time ou liga"><select class="field" id="filterInput"><option value="">Todos</option><option value="live">Ao vivo</option><option value="pre">Futuros</option><option value="post">Finalizados</option><option value="stats">Com cobertura</option></select><button class="btn" id="refreshBtn">Atualizar</button></div><button class="btn">☆ Meus Jogos</button></div><div class="content"><section><div id="mainMatch"></div><div id="summaryArea"></div><div id="modeArea"></div><div id="statsArea"></div><div class="games-list" id="gamesList"></div><div class="footer" id="footerStatus">Carregando...</div></section><aside class="right"><div class="panel"><b>🧠 Leitura com base real</b><div class="ai-box" id="aiBox"><h2>Carregando...</h2></div></div><div class="panel"><b>Base usada</b><div id="baseList" class="base"></div></div><div class="panel"><b>🎯 Jogadores que mais finalizam</b><div id="playersList" class="mini-table"></div></div><div class="panel"><b>📰 Notícias</b><div id="newsList" class="base"></div></div><div class="panel"><b>Eventos</b><div class="events" id="eventsList"></div></div></aside></div></main></div>
<script>
const $=id=>document.getElementById(id);let allGames=[],selectedGame=null,currentData=null,currentMode='winners';
function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]))}
function pct(a,b){a=Number(a)||0;b=Number(b)||0;const t=a+b;return t?Math.round((a/t)*100):50}function first(n){return String(n||'?').trim().charAt(0).toUpperCase()||'?'}function logo(t){if(t.logo)return `<div class="crest"><img src="${esc(t.logo)}"></div>`;return `<div class="crest">${esc(first(t.name))}</div>`}
function renderMain(g){selectedGame=g;localStorage.setItem('selectedGameKey',`${g.home.name}_${g.away.name}`);const badge=g.live?'AO VIVO':(g.state==='pre'?'PRÉ-JOGO':'FINALIZADO');const minute=g.minute||(g.state==='pre'?"0'":'');$('mainMatch').innerHTML=`<div class="hero"><div class="hero-inner"><div class="team">${logo(g.home)}<div class="team-name">${esc(g.home.name)}</div></div><div class="center"><div class="badge">${esc(badge)}</div><div class="period">${esc(g.status||'')}</div><div class="minute">${esc(minute)}</div><div class="score">${esc(g.home.score)} x ${esc(g.away.score)}</div><div class="venue">${esc(g.league)} · ${esc(g.source)}</div></div><div class="team">${logo(g.away)}<div class="team-name">${esc(g.away.name)}</div></div></div></div>`;renderEmpty();loadDetails(g)}
function renderEmpty(){$('summaryArea').innerHTML=`<div class="summary-grid"><div class="summary-card"><small>Pré-jogo</small><h2>Buscando contexto...</h2></div><div class="summary-card"><small>Ao vivo</small><h2>Aguardando estatísticas...</h2></div></div>`;$('statsArea').innerHTML='';$('modeArea').innerHTML='';}
function renderDetails(d){currentData=d;const a=d.analysis||{},live=a.live||{},pre=a.pregame||{},main=a.main||{};renderSummary(live,pre);renderStats(a.displayStats);renderMode();renderSide(d,main,a);renderGames()}
function renderSummary(live,pre){$('summaryArea').innerHTML=`<div class="summary-grid"><div class="summary-card"><small>Provável vencedor contextual</small><h2>${esc(pre.probableWinner||'Leitura limitada')}</h2><span class="tag ${pre.hasEnoughData?'':'bad'}">Confiança ${esc(pre.confidence||'Baixa')}</span></div><div class="summary-card"><small>Validação ao vivo</small><h2>${live.predictionScore&&live.predictionScore.total?`${live.predictionScore.good}/${live.predictionScore.total} tendências confirmando`:'Aguardando dados ao vivo'}</h2><span class="tag ${live.dataType==='live'?'':'warn'}">${live.dataType==='live'?'Tempo real':'Histórico/contexto'}</span></div></div>`}
function renderStats(s){const hist=s&&s.dataType==='historical';const f=s.finalizations||{},t=s.shotsOnGoal||{},c=s.corners||{},p=s.possession||{};const cards=[["🎯 FINALIZAÇÕES",f.home,f.away],["🥅 CHUTES NO GOL",t.home,t.away],["◔ POSSE",p.home?p.home+'%':'',p.away?p.away+'%':''],["🚩 ESCANTEIOS",c.home,c.away]];$('statsArea').innerHTML=`${hist?`<div class="panel"><b>Tendência histórica</b><p class="base">Esses números são tendência baseada em contexto/histórico, não estatística ao vivo.</p></div>`:''}<div class="stats-grid">${cards.map(ca=>{const pc=pct(parseFloat(ca[1]),parseFloat(ca[2]));return `<div class="stat-card"><div class="stat-title">${ca[0]}</div><div class="stat-values"><span>${esc(ca[1]||'-')}</span><span>${esc(ca[2]||'-')}</span></div><div class="bar"><div class="home" style="width:${pc}%"></div><div class="away" style="width:${100-pc}%"></div></div></div>`}).join('')}</div>`}
function predictionsHtml(list){if(!list||!list.length)return `<div class="base">Sem base suficiente para previsão.</div>`;return `<div class="pred-list">`+list.map(p=>`<div class="pred ${esc(p.status||'pending')}">${esc(p.label)}</div>`).join('')+`</div>`}
function renderMode(){if(!currentData)return;const a=currentData.analysis||{},live=a.live||{},pre=a.pregame||{},g=selectedGame||{};let html='';if(currentMode==='winners'){html=`<div class="panel"><div class="mode-title">🧠 Prováveis vencedores</div><p class="base">${esc(pre.reading||'Leitura limitada')}</p><div class="winner-box"><div class="winner-card"><small>${esc(g.home?.name||'Casa')}</small><br><b>${esc(pre.winPctHome||'-')}%</b></div><div class="winner-card"><small>${esc(g.away?.name||'Fora')}</small><br><b>${esc(pre.winPctAway||'-')}%</b></div></div>${predictionsHtml((live.predictions&&live.predictions.length)?live.predictions:pre.predictions)}</div>`}else if(currentMode==='post'){const p=currentData.postGame;html=`<div class="panel"><div class="mode-title">📌 Pós-jogo</div><p class="base">${esc(p?p.text:'Disponível após o fim da partida.')}</p>${p?`<div class="pred-list">${p.points.map(x=>`<div class="pred neutral">${esc(x)}</div>`).join('')}</div>`:''}</div>`}else{let title='Radar',body=(a.main&&a.main.reading)||'Leitura limitada.';if(currentMode==='final'){title='🎯 Finalizações';body=live.dataType==='live'?`Finalizações reais: ${g.home?.name}: ${live.finalizations?.home||'-'} x ${g.away?.name}: ${live.finalizations?.away||'-'}.`:'Sem finalizações ao vivo. Veja tendência histórica abaixo.'}if(currentMode==='target'){title='🥅 Chutes no gol';body=live.dataType==='live'?`Chutes no gol reais: ${g.home?.name}: ${live.shotsOnGoal?.home||'-'} x ${g.away?.name}: ${live.shotsOnGoal?.away||'-'}.`:'Sem chutes no gol ao vivo. Veja tendência histórica abaixo.'}if(currentMode==='corners'){title='🚩 Escanteios';body=live.dataType==='live'?`Escanteios reais: ${g.home?.name}: ${live.corners?.home||'-'} x ${g.away?.name}: ${live.corners?.away||'-'}.`:'Sem escanteios ao vivo. Veja tendência histórica abaixo.'}if(currentMode==='context'){title='📊 Contexto';body=(pre.base||[]).slice(0,7).join(' ')}if(currentMode==='news'){title='📰 Notícias';body=(currentData.news||[]).length?currentData.news.map(n=>n.title).join(' • '):'Notícias relevantes não encontradas.'}html=`<div class="panel"><div class="mode-title">${title}</div><p class="base">${esc(body)}</p></div>`}$('modeArea').innerHTML=html}
function renderSide(d,main,a){$('aiBox').innerHTML=`<h2>${esc(main.reading||'Leitura limitada')}</h2><p class="base">Motor: ${esc(a.contextSource||'')}</p>`;$('baseList').innerHTML=(main.base||[]).map(x=>`<div>${esc(x)}</div>`).join('')||'<div>Base parcial.</div>';renderPlayers(d.players||{});renderNews(d.news||[]);$('eventsList').innerHTML=renderEvents(d.events||[])}
function renderPlayers(players){const rows=[...(players.home||[]),...(players.away||[])].sort((a,b)=>b.shots-a.shots).slice(0,10);if(!rows.length){$('playersList').innerHTML=`<div class="base">Sem dados de jogadores disponíveis.</div>`;return}$('playersList').innerHTML=`<div class="mini-row"><b>Jogador</b><b>Fin.</b><b>Gol</b><b>Gols</b></div>`+rows.map(p=>`<div class="mini-row"><span>${esc(p.player)}</span><span>${esc(p.shots)}</span><span>${esc(p.on)}</span><span>${esc(p.goals)}</span></div>`).join('')}
function renderNews(news){$('newsList').innerHTML=news.length?news.map(n=>`<div>${esc(n.title)} <small>(${esc(n.source||'fonte')})</small></div>`).join(''):`<div>Notícias relevantes não encontradas.</div>`}
function renderEvents(events){if(!events.length)return `<div class="base">Sem eventos disponíveis.</div>`;return events.slice(-12).reverse().map(e=>`<div class="event"><b>${esc(e.minute)}</b><div>${esc(e.type)} · ${esc(e.detail)}<br><small>${esc(e.team)} ${e.player?'· '+esc(e.player):''}</small></div></div>`).join('')}
async function loadDetails(g){try{const gameParam=encodeURIComponent(JSON.stringify(g));const res=await fetch(`/api/game-details?fixtureId=${encodeURIComponent(g.fixtureId||'')}&sportmonksId=${encodeURIComponent(g.sportmonksId||'')}&game=${gameParam}&_=${Date.now()}`);const data=await res.json();if(!data.ok)throw new Error(data.error);renderDetails(data)}catch(e){$('aiBox').innerHTML=`<div class="panel">Erro: ${esc(e.message||e)}</div>`}}
function renderGames(){const q=$('searchInput').value.toLowerCase(),f=$('filterInput').value;let games=[...allGames];if(q)games=games.filter(g=>(g.home.name+' '+g.away.name+' '+g.league).toLowerCase().includes(q));if(f==='live')games=games.filter(g=>g.live);if(f==='pre')games=games.filter(g=>g.state==='pre');if(f==='post')games=games.filter(g=>g.state==='post');if(f==='stats')games=games.filter(g=>g.fixtureId||g.sportmonksId);$('gamesList').innerHTML=games.map(g=>`<div class="game-card ${selectedGame&&selectedGame.id===g.id?'active':''}" data-idx="${allGames.indexOf(g)}"><small>${esc(g.league)} ${g.live?'<span style="color:#ef4444;font-weight:900">● AO VIVO</span>':''}</small><div class="game-row"><span>${esc(g.home.name)}</span><span class="game-score">${esc(g.home.score)} x ${esc(g.away.score)}</span><span>${esc(g.away.name)}</span></div><small>${esc(g.status)} ${esc(g.minute)} · ${esc(g.time)}</small></div>`).join('');document.querySelectorAll('.game-card').forEach(c=>c.addEventListener('click',()=>{const g=allGames[Number(c.dataset.idx)];renderMain(g);renderGames()}))}
async function loadGames(){const prevKey=localStorage.getItem('selectedGameKey');$('footerStatus').textContent='Buscando jogos...';try{const date=$('dateInput').value||new Date().toISOString().slice(0,10);const res=await fetch(`/api/games?date=${date}&_=${Date.now()}`);const data=await res.json();if(!data.ok)throw new Error(data.error);allGames=data.games||[];let preferred=null;if(selectedGame){preferred=allGames.find(g=>`${g.home.name}_${g.away.name}`===`${selectedGame.home.name}_${selectedGame.away.name}`)}if(!preferred&&prevKey)preferred=allGames.find(g=>`${g.home.name}_${g.away.name}`===prevKey);if(!preferred)preferred=allGames.find(g=>g.live&&(g.sportmonksId||g.fixtureId))||allGames.find(g=>g.sportmonksId||g.fixtureId)||allGames[0];if(preferred)renderMain(preferred);else $('mainMatch').innerHTML=`<div class="panel"><div class="base">Nenhum jogo encontrado.</div></div>`;renderGames();$('footerStatus').textContent=`${allGames.length} jogos encontrados · atualizado ${new Date().toLocaleTimeString('pt-BR')}`}catch(e){$('mainMatch').innerHTML=`<div class="panel">Erro ao carregar jogos: ${esc(e.message||e)}</div>`;$('footerStatus').textContent='Erro ao atualizar'}}
document.querySelectorAll('.nav button').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('active'));btn.classList.add('active');currentMode=btn.dataset.mode;renderMode()}));$('dateInput').value=new Date().toISOString().slice(0,10);$('refreshBtn').addEventListener('click',loadGames);$('searchInput').addEventListener('input',renderGames);$('filterInput').addEventListener('change',renderGames);$('themeBtn').addEventListener('click',()=>document.body.classList.toggle('dark'));loadGames();setInterval(loadGames,60000);
</script></body></html>
